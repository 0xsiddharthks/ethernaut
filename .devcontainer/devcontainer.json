{
    "name": "Linux",
    "image": "ghcr.io/foundry-rs/foundry:latest",
    "postCreateCommand": "apt-get update && apt-get install -y python3-dev build-essential && yarn install",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": 20
        },
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": ["esbenp.prettier-vscode", "juanblanco.solidity"]
        }
    }
}
